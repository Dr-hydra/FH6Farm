<Window x:Class="OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QING.UIKIT"
        Title="FH6Auto Overlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        Width="520"
        Height="150"
        WindowStartupLocation="Manual">
    <Border CornerRadius="8"
            Background="#EEFFFFFF"
            BorderBrush="{DynamicResource ColorBrushBg0}"
            BorderThickness="1"
            Padding="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="LabOverlayTitle"
                           Text="FH6Auto"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ColorBrush3}" />
                <TextBlock x:Name="LabOverlayState"
                           Text="核心状态：空闲"
                           FontSize="13"
                           Foreground="{DynamicResource ColorBrush2}"
                           Margin="0,5,0,0" />
                <TextBlock x:Name="LabOverlayLog"
                           Text="等待任务..."
                           FontSize="12"
                           Foreground="{DynamicResource ColorBrushGray3}"
                           TextWrapping="Wrap"
                           Margin="0,6,20,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <local:MyButton x:Name="BtnOverlayStop" Text="停止" Padding="14,8" ColorType="Red" Margin="0,0,8,0" Click="BtnOverlayStop_Click" />
                <local:MyButton x:Name="BtnOverlayHide" Text="隐藏" Padding="14,8" Click="BtnOverlayHide_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
