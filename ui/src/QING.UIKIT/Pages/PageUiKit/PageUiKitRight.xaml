<local:MyPageRight x:Class="PageUiKitRight"
                   xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:local="clr-namespace:QING.UIKIT"
                   PanScroll="PanBack">
    <local:MyScrollViewer x:Name="PanBack"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="PanMain" Margin="28,24,28,14" Grid.IsSharedSizeScope="True">
            <local:MyCard Title="FH6Auto" Margin="0,0,0,15">
                <Grid Margin="20,40,20,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="LabTitle"
                                   Text="控制台"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ColorBrush3}" />
                        <TextBlock x:Name="LabSubtitle"
                                   Text="QING.UIKIT 前端控制面板，Python 自动化核心独立运行。"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   Foreground="{DynamicResource ColorBrushGray3}"
                                   Margin="0,8,20,0" />
                        <TextBlock x:Name="LabStatus"
                                   Text="核心状态：空闲"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource ColorBrush2}"
                                   Margin="0,10,20,0" />
                    </StackPanel>
                    <local:MyLoading Grid.Column="1"
                                     x:Name="LoadState"
                                     Height="42"
                                     Width="42"
                                     AutoRun="False"
                                     VerticalAlignment="Center" />
                </Grid>
            </local:MyCard>

            <local:MyCard x:Name="CardDashboard" Title="控制台" Margin="0,0,0,15">
                <StackPanel Margin="20,38,20,18">
                    <WrapPanel Margin="0,0,0,12">
                        <local:MyButton x:Name="BtnStartRace" Text="启动跑图" Padding="18,8" ColorType="Highlight" Margin="0,0,12,12" Click="BtnStartRace_Click" />
                        <local:MyButton x:Name="BtnStartBuy" Text="启动买车" Padding="18,8" Margin="0,0,12,12" Click="BtnStartBuy_Click" />
                        <local:MyButton x:Name="BtnStartCj" Text="启动抽奖" Padding="18,8" Margin="0,0,12,12" Click="BtnStartCj_Click" />
                        <local:MyButton x:Name="BtnStartSell" Text="启动移除" Padding="18,8" Margin="0,0,12,12" Click="BtnStartSell_Click" />
                        <local:MyButton x:Name="BtnStop" Text="停止核心" Padding="18,8" ColorType="Red" Margin="0,0,12,12" Click="BtnStop_Click" />
                    </WrapPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="蓝图代码" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyTextBox x:Name="TxtShareCode" Grid.Column="1" Height="34" HintText="例如 890169683" />
                    </Grid>
                    <TextBox x:Name="TxtLog"
                             Height="300"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas"
                             FontSize="12"
                             Padding="10"
                             Background="{DynamicResource ColorBrushSemiTransparent}"
                             BorderBrush="{DynamicResource ColorBrushBg0}" />
                </StackPanel>
            </local:MyCard>

            <local:MyCard x:Name="CardFlow" Title="流程" Margin="0,0,0,15">
                <StackPanel Margin="20,38,20,18">
                    <UniformGrid Columns="4" Margin="0,0,0,14">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="跑图次数" Foreground="{DynamicResource ColorBrush2}" Margin="0,0,0,6" />
                            <local:MyTextBox x:Name="TxtRaceCount" Height="34" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="买车次数" Foreground="{DynamicResource ColorBrush2}" Margin="0,0,0,6" />
                            <local:MyTextBox x:Name="TxtBuyCount" Height="34" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="抽奖次数" Foreground="{DynamicResource ColorBrush2}" Margin="0,0,0,6" />
                            <local:MyTextBox x:Name="TxtCjCount" Height="34" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="移除次数" Foreground="{DynamicResource ColorBrush2}" Margin="0,0,0,6" />
                            <local:MyTextBox x:Name="TxtScCount" Height="34" />
                        </StackPanel>
                    </UniformGrid>
                    <UniformGrid Columns="4" Margin="0,0,0,14">
                        <StackPanel Margin="0,0,12,0">
                            <local:MyCheckBox x:Name="Chk1" Text="跑图后继续" Margin="0,0,0,8" />
                            <local:MyTextBox x:Name="TxtNext1" Height="32" HintText="下一步 1-4" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <local:MyCheckBox x:Name="Chk2" Text="买车后继续" Margin="0,0,0,8" />
                            <local:MyTextBox x:Name="TxtNext2" Height="32" HintText="下一步 1-4" />
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <local:MyCheckBox x:Name="Chk3" Text="抽奖后继续" Margin="0,0,0,8" />
                            <local:MyTextBox x:Name="TxtNext3" Height="32" HintText="下一步 1-4" />
                        </StackPanel>
                        <StackPanel>
                            <local:MyCheckBox x:Name="Chk4" Text="移除后继续" Margin="0,0,0,8" />
                            <local:MyTextBox x:Name="TxtNext4" Height="32" HintText="下一步 1-4" />
                        </StackPanel>
                    </UniformGrid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="大循环次数" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyTextBox x:Name="TxtGlobalLoops" Grid.Column="1" Height="34" />
                        <TextBlock Grid.Column="2" Text="技能路径" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" Margin="20,0,0,0" />
                        <local:MyTextBox x:Name="TxtSkillDirs" Grid.Column="3" Height="34" HintText="right,up,up,up,left" />
                    </Grid>
                </StackPanel>
            </local:MyCard>

            <local:MyCard x:Name="CardOverlay" Title="悬浮窗" Margin="0,0,0,15">
                <StackPanel Margin="20,38,20,18">
                    <TextBlock Text="运行任务时可以打开置顶小窗。普通无边框窗口模式下可显示在游戏前方；独占全屏可能无法覆盖。"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ColorBrush2}"
                               Margin="0,0,0,14" />
                    <WrapPanel>
                        <local:MyButton x:Name="BtnShowOverlay" Text="显示悬浮窗" Padding="18,8" ColorType="Highlight" Margin="0,0,12,12" Click="BtnShowOverlay_Click" />
                        <local:MyButton x:Name="BtnHideOverlay" Text="隐藏悬浮窗" Padding="18,8" Margin="0,0,12,12" Click="BtnHideOverlay_Click" />
                    </WrapPanel>
                </StackPanel>
            </local:MyCard>

            <local:MyCard x:Name="CardSettings" Title="设置" Margin="0,0,0,15">
                <StackPanel Margin="20,38,20,18">
                    <local:MyCheckBox x:Name="ChkAutoRestart" Text="游戏闪退后自动重启" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="重启命令" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyTextBox x:Name="TxtRestartCmd" Grid.Column="1" Height="34" />
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="目标 CR" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyTextBox x:Name="TxtCalcA" Grid.Column="1" Height="34" />
                        <TextBlock Grid.Column="2" Text="单车成本" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" Margin="18,0,0,0" />
                        <local:MyTextBox x:Name="TxtCalcB" Grid.Column="3" Height="34" />
                    </Grid>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="单车技能点" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" />
                        <local:MyTextBox x:Name="TxtCalcC" Grid.Column="1" Height="34" />
                        <TextBlock Grid.Column="2" Text="移除模式" VerticalAlignment="Center" Foreground="{DynamicResource ColorBrush2}" Margin="18,0,0,0" />
                        <local:MyComboBox x:Name="CmbSellMode" Grid.Column="3" Height="34">
                            <ComboBoxItem Content="模式1: 识图移除模式" />
                            <ComboBoxItem Content="模式2: 移除最近添加" />
                        </local:MyComboBox>
                    </Grid>
                    <WrapPanel>
                        <local:MyButton x:Name="BtnSaveConfig" Text="保存配置" Padding="18,8" ColorType="Highlight" Margin="0,0,12,12" Click="BtnSaveConfig_Click" />
                        <local:MyButton x:Name="BtnReloadConfig" Text="重新加载" Padding="18,8" Margin="0,0,12,12" Click="BtnReloadConfig_Click" />
                    </WrapPanel>
                    <TextBlock x:Name="LabConfigPath" Text="" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,8,0,0" />
                    <TextBlock x:Name="LabRuntimeInfo" Text="" TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource ColorBrushGray3}" Margin="0,6,0,0" />
                </StackPanel>
            </local:MyCard>

            <local:MyCard x:Name="CardAbout" Title="关于" Margin="0,0,0,15">
                <StackPanel Margin="20,38,20,18">
                    <TextBlock Text="FH6Farm 保留 FH6Auto 的 Python 自动化核心，由 Dr.Hydra 开发新的 QING.UIKIT/WPF 前端。"
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{DynamicResource ColorBrush2}"
                               Margin="0,0,0,12" />
                    <local:MyListItem Title="原项目来源" Info="GitHub: YOUSTHEONE/FH6Auto" IsHitTestVisible="False" Height="54" />
                    <local:MyListItem Title="原作者" Info="YOUSTHEONE / YSTO" IsHitTestVisible="False" Height="54" />
                    <local:MyListItem Title="UI 开发" Info="Dr.Hydra：QING.UIKIT、VB.NET/WPF 前端与 Python core bridge" IsHitTestVisible="False" Height="54" />
                    <local:MyListItem Title="UI 设计参考" Info="PCL（Plain Craft Launcher），本项目与 PCL 官方无隶属关系" IsHitTestVisible="False" Height="54" />
                    <local:MyListItem Title="当前策略" Info="前端负责配置、日志、悬浮窗；Python 负责识图、键鼠和流程执行" IsHitTestVisible="False" Height="54" />
                </StackPanel>
            </local:MyCard>
        </StackPanel>
    </local:MyScrollViewer>
</local:MyPageRight>
